resource_group_name = "rg-medstock-dev"
location            = "eastus"
environment         = "dev"

vnet_name         = "vnet-medstock-dev"
vnet_address_space = ["10.10.0.0/16"]

subnet_name              = "snet-app"
subnet_address_prefixes  = ["10.10.1.0/24"]

nsg_name = "nsg-medstock-dev"

public_ip_name = "pip-medstock-dev"
nic_name       = "nic-medstock-dev"

# Restrict this to your own IP range in production — never leave as 0.0.0.0/0
allowed_source_ip = "0.0.0.0/0"

app_port = 5000

tags = {
  project     = "medstock-monitor"
  environment = "dev"
  managedBy   = "terraform"
}
